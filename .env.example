# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AgentDesk AI

# Local UI without Supabase (demo org + mock providers). Set false when using real Auth.
LOCAL_DEMO_MODE=true
NEXT_PUBLIC_LOCAL_DEMO_MODE=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Auth redirects
NEXT_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Provider selection (mock = local development without external accounts)
VOICE_PROVIDER=mock
TELEPHONY_PROVIDER=mock
BILLING_PROVIDER=mock
CALENDAR_PROVIDER=mock
JOBS_PROVIDER=local

# Retell AI (when VOICE_PROVIDER=retell)
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# Twilio (when TELEPHONY_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=http://localhost:3000

# Stripe (when BILLING_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_BUSINESS_ANNUAL=

# Email
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=calls@yourdomain.com

# Observability (optional)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Security
INTEGRATION_SECRETS_ENCRYPTION_KEY=change-me-32-chars-minimum!!!!
INTERNAL_API_SECRET=change-me-in-production

# --- Legacy (deprecated — not used by AgentDesk Phase 1) ---
# CLERK_* / DEEPGRAM_API_KEY / VOICE_WORKER_* / OPENAI_* for old VoiceLead worker
